{
  "name": "ai-learning-resource-tool",
  "private": true,
  "version": "0.1.0",
  "description": "AI learning resource hub workspace for Windows + Ollama + Vibe Coding.",
  "scripts": {
    "check:env": "powershell -ExecutionPolicy Bypass -File ./scripts/check-env.ps1",
    "preview": "wrangler dev",
    "preview:8080": "powershell -ExecutionPolicy Bypass -File ./scripts/start-preview.ps1 -Port 8080",
    "deploy": "wrangler deploy",
    "ops:update": "node ./scripts/ops-update.js",
    "agent:resource-search": "node ./scripts/resource-search-agent.js",
    "agent:content-watch": "node ./scripts/content-watch-agent.js",
    "agent:ai-daily": "node ./scripts/ai-daily-agent.js",
    "ops:light": "node ./scripts/content-watch-agent.js && node ./scripts/ai-daily-agent.js",
    "ops:daily": "node ./scripts/content-watch-agent.js && node ./scripts/resource-search-agent.js && node ./scripts/ai-daily-agent.js && node ./scripts/ops-update.js && powershell -ExecutionPolicy Bypass -File ./scripts/check-env.ps1",
    "ops:publish": "powershell -ExecutionPolicy Bypass -File ./scripts/publish-daily-site.ps1",
    "ops:register-daily": "powershell -ExecutionPolicy Bypass -File ./scripts/register-daily-ops-task.ps1 -At 20:00"
  },
  "devDependencies": {
    "wrangler": "^4.102.0"
  }
}
