{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "ai-learning-resource-tool",
  "main": "src/worker.js",
  "compatibility_date": "2026-06-18",
  "observability": {
    "enabled": true
  },
  "assets": {
    "directory": "site",
    "binding": "ASSETS",
    "run_worker_first": [
      "/wechat"
    ]
  },
  "compatibility_flags": [
    "nodejs_compat"
  ]
}
