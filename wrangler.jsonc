{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "ai-learning-resource-tool",
  "main": "src/worker.js",
  "compatibility_date": "2026-06-18",
  "observability": {
    "enabled": true
  },
  "vars": {
    "WECHAT_OFFICIAL_ACCOUNT_NAME": "憨憨的学习空间",
    "WECHAT_CONTACT_WECHAT_ID": "hanbaobao_-1998"
  },
  "assets": {
    "directory": "site",
    "binding": "ASSETS",
    "run_worker_first": [
      "/wechat"
    ]
  },
  "compatibility_flags": [
    "nodejs_compat"
  ]
}
